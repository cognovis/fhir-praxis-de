CodeSystem: GenehmigungenLeistungsbereichCS
Id: genehmigung-leistungsbereich
Title: "Genehmigung Leistungsbereich"
Description: "KV-regulierte Leistungsbereiche mit Genehmigungspflicht. Offene Liste (extensible) zur Erweiterbarkeit fuer dentale und weitere Fachgebiete."
* ^status = #active
* ^experimental = false
* ^caseSensitive = true
* ^hierarchyMeaning = #is-a
* ^property[+].code = #parent
* ^property[=].uri = "http://hl7.org/fhir/concept-properties#parent"
* ^property[=].type = #code

