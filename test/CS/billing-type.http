### Test: $lookup invalid code "INVALID_XYZ"
# Expected: OperationOutcome error or empty result
# RESULT: FAIL — returns {"total":0,"entry":[]} (same as valid codes)
GET http://localhost:8080/fhir/CodeSystem/$lookup?system=https://fhir.cognovis.de/praxis/CodeSystem/billing-type&code=INVALID_XYZ
Authorization: Basic basic:secret

### Workaround: Aidbox Concept API — verify "ebm" exists
# Expected: total=1, code=ebm, display=EBM
# RESULT: PASS — 9 concepts loaded
GET http://localhost:8080/Concept?system=https://fhir.cognovis.de/praxis/CodeSystem/billing-type&code=ebm&_count=1
Authorization: Basic basic:secret

