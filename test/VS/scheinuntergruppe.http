GET http://localhost:8080/ValueSet/kvdt-scheinuntergruppe/$validate-code?system=https://fhir.cognovis.de/praxis/CodeSystem/kvdt-scheinuntergruppe&code=0101
Authorization: Basic basic:secret

?? status == 200
?? body.parameter[0].valueBoolean == true

