### ValueSet: KvdtScheinuntergruppe - $expand
# @name expand
# Expected: Bundle mit allen Codes aus KvdtScheinuntergruppeCS (S_KBV_SCHEINART V1.02)
GET http://localhost:8080/ValueSet/kvdt-scheinuntergruppe/$expand
Authorization: Basic basic:secret

?? status == 200

### ValueSet: KvdtScheinuntergruppe - $validate-code valid (00 = Behandlungsausweis)
# @name validate_valid_1
# Expected: Parameters mit result=true
GET http://localhost:8080/ValueSet/kvdt-scheinuntergruppe/$validate-code?system=https://fhir.cognovis.de/praxis/CodeSystem/kvdt-scheinuntergruppe&code=00
Authorization: Basic basic:secret

?? status == 200
?? body.parameter[0].valueBoolean == true

