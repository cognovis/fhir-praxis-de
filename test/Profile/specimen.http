### Validate PraxisSpecimen — Venaeses Blut EDTA (SNOMED + LDT dual coding)
# @name validate-specimen-blut-edta
# Expected: OperationOutcome with "all ok" (no errors)
# Covers: dual coding SNOMED+LDT, identifier, collection.method, container.type
POST http://localhost:8080/fhir/Specimen/$validate?profile=https://fhir.cognovis.de/praxis/StructureDefinition/praxis-specimen
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Specimen",
  "meta": {
    "profile": ["https://fhir.cognovis.de/praxis/StructureDefinition/praxis-specimen"]
  },
  "identifier": [
    {
      "system": "https://labor-beispiel.de/proben-id",
      "value": "BL-2026-00147"
    }
  ],
  "type": {
    "coding": [
      {
        "system": "http://snomed.info/sct",
        "code": "122555007",
        "display": "Venous blood specimen"
      },
      {
        "system": "https://fhir.cognovis.de/praxis/CodeSystem/ldt-materialbezeichnung",
        "code": "EDTA-Blut",
        "display": "EDTA-Blut"
      }
    ]
  },
  "subject": { "reference": "Patient/example-patient" },
  "collection": {
    "collectedDateTime": "2026-04-05T08:30:00+02:00",
    "method": {
      "coding": [{ "system": "http://snomed.info/sct", "code": "28520004", "display": "Venipuncture" }]
    }
  },
  "container": [
    {
      "type": {
        "coding": [{ "system": "http://snomed.info/sct", "code": "702281005", "display": "EDTA tube" }]
      }
    }
  ]
}

?? status == 200


