### Validate PraxisDevice — Roche Cobas 6000 Laboranalyzer
# @name validate-device-cobas
# Expected: OperationOutcome with "all ok" (no errors)
# Covers: identifier[gdtId] slice, deviceName, manufacturer, modelNumber, version, type, status
POST http://localhost:8080/fhir/Device/$validate?profile=https://fhir.cognovis.de/praxis/StructureDefinition/praxis-device
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Device",
  "meta": {
    "profile": ["https://fhir.cognovis.de/praxis/StructureDefinition/praxis-device"]
  },
  "status": "active",
  "identifier": [
    {
      "system": "https://fhir.cognovis.de/praxis/NamingSystem/gdt-device-id",
      "value": "COBAS6000-LAB01"
    }
  ],
  "deviceName": [
    {
      "name": "Cobas 6000",
      "type": "manufacturer-name"
    }
  ],
  "manufacturer": "Roche Diagnostics GmbH",
  "modelNumber": "Cobas 6000",
  "version": [
    { "value": "3.5.1" }
  ],
  "type": {
    "coding": [
      {
        "system": "http://snomed.info/sct",
        "code": "30234008",
        "display": "Medical laboratory analyzer"
      }
    ]
  }
}

?? status == 200


