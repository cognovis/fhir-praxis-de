### Negativ-Test: billing-assignment darf nicht auf Patient zeigen
# @name coverage-privat-billing-assignment-invalid
# Expected: OperationOutcome with errors (Reference target must be Organization)
POST http://localhost:8080/fhir/Coverage/$validate?profile=https://fhir.cognovis.de/praxis/StructureDefinition/fpde-coverage-privat
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Coverage",
  "status": "active",
  "type": {
    "coding": [{
      "system": "http://fhir.de/CodeSystem/versicherungsart-de-basis",
      "code": "PKV"
    }]
  },
  "beneficiary": {
    "reference": "Patient/example"
  },
  "payor": [{
    "reference": "Organization/example-pkv"
  }],
  "extension": [{
    "url": "https://fhir.cognovis.de/praxis/StructureDefinition/billing-assignment",
