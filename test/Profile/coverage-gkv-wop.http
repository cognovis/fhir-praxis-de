### GKV-Coverage mit WOP Nordrhein
# @name coverage-gkv-wop-nordrhein
# Expected: OperationOutcome with "all ok" (no errors)
# AK3: WOP Extension (http://fhir.de/StructureDefinition/gkv/wop) aus de.basisprofil.r4
# Extension wird NICHT neu definiert — direkt aus Upstream-Paket verwendet
POST http://localhost:8080/fhir/Coverage/$validate?profile=https://fhir.cognovis.de/praxis/StructureDefinition/fpde-coverage-gkv
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Coverage",
  "status": "active",
  "type": {
    "coding": [{
      "system": "http://fhir.de/CodeSystem/versicherungsart-de-basis",
      "code": "GKV",
      "display": "gesetzliche Krankenversicherung"
    }]
  },
  "beneficiary": {
    "reference": "Patient/example"
  },
  "payor": [{
    "display": "AOK Rheinland/Hamburg"
  }],
  "extension": [{
    "url": "http://fhir.de/StructureDefinition/gkv/wop",
    "valueCoding": {
      "system": "https://fhir.kbv.de/CodeSystem/KBV_CS_SFHIR_ITA_WOP",
      "code": "38",
      "display": "Nordrhein"
    }
  }]
}

###

### PKV-Coverage mit billing-assignment an PVS
# @name coverage-privat-billing-assignment
# Expected: OperationOutcome with "all ok" (no errors)
POST http://localhost:8080/fhir/Coverage/$validate?profile=https://fhir.cognovis.de/praxis/StructureDefinition/fpde-coverage-privat
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Coverage",
  "status": "active",
  "type": {
    "coding": [{
      "system": "http://fhir.de/CodeSystem/versicherungsart-de-basis",
      "code": "PKV",
      "display": "private Krankenversicherung"
    }]
  },
  "subscriber": {
    "reference": "Patient/example"
  },
  "beneficiary": {
    "reference": "Patient/example"
  },
  "payor": [{
    "reference": "Organization/example-pkv"
  }],
  "extension": [{
    "url": "https://fhir.cognovis.de/praxis/StructureDefinition/billing-assignment",
    "valueReference": {
      "reference": "Organization/example-pvs"
    }
  }]
}

