### Consent mit HPAYMT und Coverage-spezifischer PVS-Freigabe
# @name consent-billing-assignment
# Expected: OperationOutcome with "all ok" (no errors)
POST http://localhost:8080/fhir/Consent/$validate
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Consent",
  "status": "active",
  "scope": {
    "coding": [{
      "system": "http://terminology.hl7.org/CodeSystem/consentscope",
      "code": "patient-privacy"
    }]
  },
  "category": [{
    "coding": [{
      "system": "http://terminology.hl7.org/CodeSystem/v3-ActCode",
      "code": "IDSCL"
    }]
  }],
  "patient": {
    "reference": "Patient/example"
  },
  "dateTime": "2026-01-10",
  "policyRule": "http://terminology.hl7.org/CodeSystem/v3-ActCode#OPTIN",
  "provision": {
    "type": "permit",
    "purpose": [{
      "system": "http://terminology.hl7.org/CodeSystem/v3-ActReason",
      "code": "HPAYMT",
      "display": "healthcare payment"
    }],
    "actor": [{
      "role": {
        "coding": [{
          "system": "http://terminology.hl7.org/CodeSystem/v3-ParticipationType",
          "code": "IRCP"
        }]
      },
      "reference": {
        "reference": "Organization/example-pvs"
      }
    }],
    "data": [{
      "meaning": "related",
      "reference": {
        "reference": "Coverage/example-coverage-privat"
      }
    }]
  }
}
