### Erstanamnese Questionnaire-Template validieren
# @name validate-anamnese-questionnaire
# Expected: OperationOutcome with "all ok" (no errors)
# Validates AnamneseQuestionnaire example against custom profile
# Fills: status, title, date, publisher, subjectType, item, item.linkId, item.text, item.type, item.required, useContext[bogentyp], extension[kategorie]
POST http://localhost:8080/fhir/Questionnaire/$validate?profile=https://fhir.cognovis.de/praxis/StructureDefinition/anamnese-questionnaire
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Questionnaire",
  "id": "example-anamnese-erstanamnese",
  "meta": {
    "profile": ["https://fhir.cognovis.de/praxis/StructureDefinition/anamnese-questionnaire"]
  },
  "extension": [
    {
      "url": "https://fhir.cognovis.de/praxis/StructureDefinition/questionnaire-kategorie",
      "valueString": "Allgemeinmedizin"
    }
  ],
  "url": "https://fhir.cognovis.de/praxis/Questionnaire/example-anamnese-erstanamnese",
  "version": "1.0.0",
  "title": "Erstanamnese — Allgemeinmedizin",
  "status": "active",
  "date": "2026-01-01",
  "publisher": "cognovis GmbH",
  "description": "Standardisierter Anamnesebogen fuer die allgemeinmedizinische Erstuntersuchung.",
  "subjectType": ["Patient"],
  "useContext": [
    {
      "code": {
        "system": "http://terminology.hl7.org/CodeSystem/usage-context-type",
        "code": "workflow"
      },
      "valueCodeableConcept": {
        "coding": [
          {
            "system": "https://fhir.cognovis.de/praxis/CodeSystem/anamnese-bogentyp",
            "code": "erstanamnese",
            "display": "Erstanamnese"
          }
        ]
      }
    }
  ],
  "item": [
    {
      "linkId": "1",
      "text": "Vorerkrankungen",
      "type": "group",
      "required": false,
      "item": [
        {
          "linkId": "1.1",
          "text": "Bekannte Vorerkrankungen",
          "type": "text",
          "required": false
        },
        {
          "linkId": "1.2",
          "text": "Frueherer Krankenhausaufenthalt?",
          "type": "boolean",
          "required": false
        },
        {
          "linkId": "1.3",
          "text": "Bekannte Allergien",
          "type": "text",
          "required": false
        }
      ]
    },
    {
      "linkId": "2",
      "text": "Medikation",
      "type": "group",
      "required": false,
      "item": [
        {
          "linkId": "2.1",
          "text": "Aktuelle Dauermedikation",
          "type": "text",
          "required": false
        },
        {
          "linkId": "2.2",
          "text": "Unvertraeglichkeiten bekannt?",
          "type": "boolean",
          "required": false
        }
      ]
    },
    {
      "linkId": "3",
      "text": "Sozialanamnese",
      "type": "group",
      "required": false,
      "item": [
        {
          "linkId": "3.1",
          "text": "Beruf",
          "type": "string",
          "required": false
        },
        {
          "linkId": "3.2",
          "text": "Raucherstatus",
          "type": "string",
          "required": false
        }
      ]
    }
  ]
}

###

### Negativ-Test: Questionnaire ohne title (1..1 MS) muss Fehler liefern
# @name anamnese-questionnaire-missing-title
# Expected: OperationOutcome with errors (title is 1..1)
# Verifies that the profile constraint on title actually fires
POST http://localhost:8080/fhir/Questionnaire/$validate?profile=https://fhir.cognovis.de/praxis/StructureDefinition/anamnese-questionnaire
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Questionnaire",
  "id": "example-anamnese-missing-title",
  "meta": {
    "profile": ["https://fhir.cognovis.de/praxis/StructureDefinition/anamnese-questionnaire"]
  },
  "status": "active",
  "date": "2026-01-01",
  "publisher": "cognovis GmbH",
  "subjectType": ["Patient"],
  "useContext": [
    {
      "code": {
        "system": "http://terminology.hl7.org/CodeSystem/usage-context-type",
        "code": "workflow"
      },
      "valueCodeableConcept": {
        "coding": [
          {
            "system": "https://fhir.cognovis.de/praxis/CodeSystem/anamnese-bogentyp",
            "code": "erstanamnese",
            "display": "Erstanamnese"
          }
        ]
      }
    }
  ],
  "item": [
    {
      "linkId": "1",
      "text": "Vorerkrankungen",
      "type": "group",
      "required": false
    }
  ]
}
