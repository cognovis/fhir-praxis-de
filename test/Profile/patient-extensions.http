### Patient with patient-seit extension (Bestandspatient)
# @name patient-with-patient-seit
# Expected: OperationOutcome with "all ok" (no errors)
POST http://localhost:8080/fhir/Patient/$validate
Authorization: Basic basic:secret
Content-Type: application/fhir+json

{
  "resourceType": "Patient",
  "extension": [{
    "url": "https://fhir.cognovis.de/praxis/StructureDefinition/patient-seit",
    "valueDate": "2015-03-15"
  }],
  "name": [{
    "use": "official",
    "family": "Mustermann",
    "given": ["Max"]
  }],
  "birthDate": "1975-06-20"
}

