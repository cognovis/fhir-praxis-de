            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "Device.extension:deviceMaintenanceStatus",
        "path": "Device.extension",
        "sliceName": "deviceMaintenanceStatus",
