{
  "resourceType": "StructureDefinition",
  "id": "image-km-administration",
  "url": "https://fhir.cognovis.de/praxis/StructureDefinition/image-km-administration",
  "name": "ImageKmAdministrationExt",
  "title": "Image KM Administration",
  "status": "active",
  "experimental": false,
  "description": "Kontrastmittel-Gabe bei bildgebenden Untersuchungen. Dokumentiert ob KM verabreicht wurde, welches Mittel (ATC-Klassifikation), Dosis, Applikationsweg und ggf. GOAe-Abrechnungsziffer fuer die KM-Gabe.",
  "fhirVersion": "4.0.1",
  "kind": "complex-type",
  "abstract": false,
  "context": [
    {
      "type": "element",
      "expression": "ImagingStudy"
    }
  ],
  "type": "Extension",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Extension",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Extension",
        "path": "Extension",
        "short": "Image KM Administration",
        "definition": "Kontrastmittel-Gabe bei bildgebenden Untersuchungen. Dokumentiert ob KM verabreicht wurde, welches Mittel (ATC-Klassifikation), Dosis, Applikationsweg und ggf. GOAe-Abrechnungsziffer fuer die KM-Gabe."
      },
      {
        "id": "Extension.extension",
        "path": "Extension.extension",
        "min": 1
      },
      {
        "id": "Extension.extension:administered",
        "path": "Extension.extension",
        "sliceName": "administered",
        "short": "Kontrastmittel verabreicht (ja/nein)",
        "definition": "Gibt an ob ein Kontrastmittel verabreicht wurde. Pflichtfeld.",
        "min": 1,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Extension.extension:administered.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:administered.url",
        "path": "Extension.extension.url",
        "fixedUri": "administered"
      },
      {
        "id": "Extension.extension:administered.value[x]",
        "path": "Extension.extension.value[x]",
        "type": [
          {
            "code": "boolean"
          }
        ]
      },
      {
        "id": "Extension.extension:agent-atc",
        "path": "Extension.extension",
        "sliceName": "agent-atc",
        "short": "Kontrastmittel ATC-Klassifikation",
        "definition": "ATC-Klassifikation des verabreichten Kontrastmittels (z.B. V08CA fuer gadoliniumhaltige MRT-Kontrastmittel).",
        "min": 0,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Extension.extension:agent-atc.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:agent-atc.url",
        "path": "Extension.extension.url",
        "fixedUri": "agent-atc"
      },
      {
        "id": "Extension.extension:agent-atc.value[x]",
        "path": "Extension.extension.value[x]",
        "type": [
          {
            "code": "CodeableConcept"
          }
        ],
        "binding": {
          "strength": "preferred",
          "valueSet": "https://fhir.cognovis.de/imaging/ValueSet/contrast-agent-atc"
        }
      },
      {
        "id": "Extension.extension:agent-name",
        "path": "Extension.extension",
        "sliceName": "agent-name",
        "short": "Kontrastmittel Freitext-Name",
        "definition": "Freitextangabe des Handelsnamens oder Wirkstoffnamens des Kontrastmittels.",
        "min": 0,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Extension.extension:agent-name.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:agent-name.url",
        "path": "Extension.extension.url",
        "fixedUri": "agent-name"
      },
      {
        "id": "Extension.extension:agent-name.value[x]",
        "path": "Extension.extension.value[x]",
        "type": [
          {
            "code": "string"
          }
        ]
      },
      {
        "id": "Extension.extension:dose-ml",
        "path": "Extension.extension",
        "sliceName": "dose-ml",
        "short": "Kontrastmittel-Dosis in ml",
        "definition": "Verabreichte Menge des Kontrastmittels in Milliliter.",
        "min": 0,
        "max": "1",
        "mustSupport": true
      },
      {
        "id": "Extension.extension:dose-ml.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:dose-ml.url",
        "path": "Extension.extension.url",
        "fixedUri": "dose-ml"
      },
      {
        "id": "Extension.extension:dose-ml.value[x]",
        "path": "Extension.extension.value[x]",
        "type": [
          {
            "code": "Quantity"
          }
        ]
      },
      {
        "id": "Extension.extension:dose-ml.value[x].system",
        "path": "Extension.extension.value[x].system",
        "patternUri": "http://unitsofmeasure.org"
      },
      {
        "id": "Extension.extension:dose-ml.value[x].code",
        "path": "Extension.extension.value[x].code",
        "patternCode": "mL"
      },
      {
        "id": "Extension.extension:route",
        "path": "Extension.extension",
        "sliceName": "route",
        "short": "Applikationsweg",
        "definition": "Art der Verabreichung des Kontrastmittels (z.B. intravenoese Gabe).",
        "min": 0,
        "max": "1"
      },
      {
        "id": "Extension.extension:route.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:route.url",
        "path": "Extension.extension.url",
        "fixedUri": "route"
      },
      {
        "id": "Extension.extension:route.value[x]",
        "path": "Extension.extension.value[x]",
        "type": [
          {
            "code": "CodeableConcept"
          }
        ],
        "binding": {
          "strength": "preferred",
          "valueSet": "http://hl7.org/fhir/ValueSet/route-codes"
        }
      },
      {
        "id": "Extension.extension:goae-reference",
        "path": "Extension.extension",
        "sliceName": "goae-reference",
        "short": "GOAe-Abrechnungsziffer fuer KM-Gabe",
        "definition": "Referenz auf die GOAe ChargeItemDefinition fuer die Abrechnung der Kontrastmittel-Gabe.",
        "min": 0,
        "max": "1"
      },
      {
        "id": "Extension.extension:goae-reference.extension",
        "path": "Extension.extension.extension",
        "max": "0"
      },
      {
        "id": "Extension.extension:goae-reference.url",
        "path": "Extension.extension.url",
        "fixedUri": "goae-reference"
      },
      {
        "id": "Extension.extension:goae-reference.value[x]",
        "path": "Extension.extension.value[x]",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/StructureDefinition/ChargeItemDefinition"
            ]
          }
        ]
      },
      {
        "id": "Extension.url",
        "path": "Extension.url",
        "fixedUri": "https://fhir.cognovis.de/praxis/StructureDefinition/image-km-administration"
      },
      {
        "id": "Extension.value[x]",
        "path": "Extension.value[x]",
        "max": "0"
      }
    ]
  }
}
